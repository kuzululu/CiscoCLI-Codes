Cisco Command

!@BASIC SECURITY
line console 0
password cisco
login
exit
line vty 0 15
password cisco
login
exit
service password-encryption

@STEP 1 - Create Voice VLAN
conf t
vlan #
 name VLAn-Name

@Verify
do show vlan brief

@STEP 2 - Assign Ports
@Ito ang unang bagong command.
@Lahat ng phones ay nasa Fa0/1 hanggang Fa0/7.

conf t
interface range #
switchport voice vlan #
spanning-tree portfast

@for verification
show running-config interface fa0/1
show interfaces switchport fa0/1

@STEP 3 - Create the SVI
 conf t
 interface vlan 200
 ip address 172.16.50.1 255.255.255.192
 no shutdown

@Verify
show ip interface brief

@STEP 4 - Enable Routing
conf t
ip routing

@exclude ip address
conf t
ip dhcp excluded-address 172.16.50.1

@create DHCP POOL
conf t
ip dhcp pool VLAn_name
network 172.16.50.0 255.255.255.192
default-router 172.16.50.1
option 150 ip 172.16.50.1 //@! here is the SVI or default server of call manager

@verify the dhcp
show ip dhcp binding
